{
    "name": "phpdot/queue",
    "description": "RabbitMQ messaging for PHP: publish, consume, retry, dead letter.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": ["rabbitmq", "amqp", "queue", "messaging", "retry", "dead-letter"],
    "require": {
        "php": ">=8.3",
        "php-amqplib/php-amqplib": "^3.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Queue\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Queue\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --exclude-group integration",
        "test-all": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
